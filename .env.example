# =============================================
# Diana — Environment Configuration Template
# Copy this file to .env and fill in your values
# =============================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/diana

# --- League of Legends Bot (Diana) ---
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-client-id-here

# --- Apex Legends Bot (Pathfinder) ---
APEX_DISCORD_BOT_TOKEN=your-apex-discord-bot-token-here
APEX_DISCORD_CLIENT_ID=your-apex-discord-client-id-here

# --- API Keys ---
RIOT_API_KEY=RGAPI-your-riot-api-key-here
APEX_API_KEY=your-mozambiquehe-re-api-key-here

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-secure-random-string-here

# --- Optional ---
PORT=3000
# DISCORD_GUILD_ID=         # Restrict slash commands to one server (faster for dev)
# DISCORD_CHANNEL_ID=       # Default notification channel
# DIANA_CONFIG_DIR=./data   # Directory for plugins.json state file

# --- Feature flags ---
# USE_RIOT_API=true          # Use real Riot API (default: false, uses mock data)
# MOCK_APEX_SERVICE=false    # Force mock Apex data
# FORCE_DEVELOPMENT_TIMERS=false  # Use shorter poll intervals for dev
# STOP_BOT=false             # Disable all background jobs
# DISABLE_DISCORD_POSTS=false     # Don't send Discord messages (dry run)

# --- Support link (shown on match end embeds) ---
# SUPPORT_URL=https://buymeacoffee.com/yngstew

# --- Meeps webhook (optional external notifications) ---
# MEEPS_WEBHOOK_URL=
# MEEPS_WEBHOOK_SECRET=
