{
    "name": "diana-server",
    "version": "2.0.2",
    "private": true,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "dev": "nodemon --watch src --ext ts,tsx --exec ts-node src/index.ts",
        "dev:debug": "nodemon --watch src --ext ts,tsx --exec \"node --inspect -r ts-node/register src/index.ts\"",
        "start": "node dist/index.js",
        "build": "tsc -b",
        "build:check": "tsc -b",
        "user": "ts-node scripts/addUser.ts",
        "announce": "ts-node scripts/announce.ts"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "cookie-parser": "^1.4.7",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "diana-core": "2.0.5",
        "diana-discord": "2.0.0",
        "dotenv": "^17.3.1"
    },
    "devDependencies": {
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2"
    }
}
