{
    "name": "diana",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*",
        "dashboard"
    ],
    "scripts": {
        "dev": "concurrently -k -n backend,dashboard -c blue,magenta \"npm run dev --workspace apps/server\" \"npm run dev --workspace dashboard\"",
        "dev:backend": "npm run dev --workspace apps/server",
        "dev:dashboard": "npm run dev --workspace dashboard",
        "dev:debug": "npm run dev:debug --workspace apps/server",
        "start": "npm run start --workspace apps/server",
        "build": "npm run build --workspaces --if-present",
        "build:dashboard": "npm run build --workspace dashboard",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint --fix --ext .js,.jsx .",
        "lint:check": "eslint --ext .js,.jsx .",
        "build:check": "npm run build:check --workspaces --if-present",
        "db:init": "psql $DATABASE_URL -f db/init/data.sql",
        "db:seed": "psql $DATABASE_URL -f db/seed.sql",
        "backfill:matches": "npm run backfill:matches --workspace diana-core",
        "user": "npm run user --workspace apps/server",
        "precommit": "npm run lint && npm run format && npm run build && npm run test",
        "prepare": "husky"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "Diana - plugin-based Discord bot with dashboard.",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/recommended": "^1.0.13",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-rate-limit": "^6.0.2",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.5.0",
        "@types/node-cron": "^3.0.11",
        "babel-jest": "^30.2.0",
        "concurrently": "^9.2.1",
        "eslint": "^10.0.1",
        "globals": "^17.3.0",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "prettier": "3.8.1",
        "ts-jest": "^29.4.6",
        "typescript": "^5.9.3"
    }
}
